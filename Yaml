    <script>
        // 1. Initialize the terminal
        const term = new Terminal({
            cursorBlink: true,
            theme: {
                background: '#000000',
                foreground: '#f8f8f2',
                cursor: '#f8f8f0',
                selectionBackground: '#44475a'
            },
            fontFamily: '"Fira Code", monospace',
            fontSize: 16
        });

        // 2. Attach terminal to the DOM container
        term.open(document.getElementById('terminal-container'));

        // Welcome Text
        term.writeln('Welcome to the Web Terminal! 🚀');
        term.writeln('Type "help" to see available commands.\r\n');

        const prompt = 'guest@web-terminal:~$ ';
        term.write(prompt);

        let currentLine = '';

        // 3. Handle Keyboard Inputs
        term.onData(e => {
            switch (e) {
                case '\r': // Enter key
                    term.write('\r\n');
                    handleCommand(currentLine.trim());
                    currentLine = '';
                    break;
                case '\u007F': // Backspace key
                    // Do not delete the prompt
                    if (currentLine.length > 0) {
                        currentLine = currentLine.slice(0, -1);
                        term.write('\b \b'); // backspace, space, backspace to erase character
                    }
                    break;
                default: // All other printable characters
                    // Only accept standard characters
                    if (e >= String.fromCharCode(0x20) && e <= String.fromCharCode(0x7E)) {
                        currentLine += e;
                        term.write(e);
                    }
            }
        });

        // 4. Create your Command Parser
        function handleCommand(command) {
            const args = command.split(' ');
            const cmd = args[0].toLowerCase();

            if (cmd === '') {
                term.write(prompt);
                return;
            }

            switch (cmd) {
                case 'help':
                    term.writeln('Available commands:');
                    term.writeln('  help    - Show this menu');
                    term.writeln('  clear   - Clear the terminal screen');
                    term.writeln('  about   - Learn more about this app');
                    term.writeln('  echo    - Print text back (e.g., echo hello)');
                    term.writeln('  date    - Display current date and time');
                    break;

                case 'clear':
                    term.clear();
                    break;

                case 'about':
                    term.writeln('Web Terminal App v1.0.0');
                    term.writeln('Built using Xterm.js for ultimate performance and accuracy.');
                    break;

                case 'echo':
                    const text = args.slice(1).join(' ');
                    term.writeln(text);
                    break;

                case 'date':
                    term.writeln(new Date().toString());
                    break;

                default:
                    term.writeln(`command not found: ${cmd}`);
            }

            // Always reprint prompt after a command finishes
            term.write(prompt);
        }
    </script>

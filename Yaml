import express from 'express';
import { authenticateToken, requirePermission } from '../middleware/authMiddleware.js';
import { PERMISSIONS } from '../config/permissions.js';

const router = express.Router();

// 1. All routes in this file require a valid logged-in user
router.use(authenticateToken);

// 2. View users endpoint (Accessible by Viewer, Support, Admin, Superadmin)
router.get('/', 
  requirePermission(PERMISSIONS.USERS_VIEW), 
  (req, res) => res.json({ msg: "Here is your user data list" })
);

// 3. Create user endpoint (Accessible by Support, Admin, Superadmin)
router.post('/', 
  requirePermission(PERMISSIONS.USERS_CREATE), 
  (req, res) => res.json({ msg: "User successfully created" })
);

// 4. Delete user endpoint (Accessible by Admin and Superadmin only)
router.delete('/:id', 
  requirePermission(PERMISSIONS.USERS_DELETE), 
  (req, res) => res.json({ msg: "User successfully deleted" })
);

export default router;
